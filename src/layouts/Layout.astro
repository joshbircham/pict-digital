---
interface Props {
  title?: string;
  description?: string;
  image?: string;
  ogType?: string;
  publishedTime?: Date;
  author?: string;
}
const {
  title = 'Pict Digital',
  description = 'Boutique creative consultancy based in Aberdeen, Scotland. Narrative video, creative campaigns, and place-based storytelling.',
  image,
  ogType = 'website',
  publishedTime,
  author,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = image
  ? new URL(image, Astro.site).toString()
  : new URL('/images/pict-forest-image.jpg', Astro.site).toString();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="icon" href="/favicon.ico" sizes="16x16 32x32 48x48" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Pict Digital" />
    {publishedTime && <meta property="article:published_time" content={publishedTime.toISOString()} />}
    {author && <meta property="article:author" content={author} />}
    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <!-- Google Analytics -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-RKGVH54XEV"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-RKGVH54XEV');
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Preload the font CSS so the browser starts the font download chain earlier -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,900;1,400;1,500&family=Inter:wght@300;400;500&display=swap" as="style" />
    <!-- Load non-blocking: media=print trick defers parse until after first paint -->
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,900;1,400;1,500&family=Inter:wght@300;400;500&display=swap" media="print" onload="this.media='all'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Big+Shoulders+Display:wght@400;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,700;0,900;1,400;1,500&family=Inter:wght@300;400;500&display=swap" /></noscript>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /*
   * Metric-adjusted fallback for Playfair Display.
   * size-adjust 97.5% = Playfair cap-height (698) / Georgia cap-height (716).
   * ascent/descent overrides keep line-box height consistent so text doesn't
   * jump vertically when the webfont swaps in.
   */
  @font-face {
    font-family: 'Playfair Display Fallback';
    src: local('Georgia'), local('Times New Roman');
    size-adjust: 97.5%;
    ascent-override: 90%;
    descent-override: 27%;
    line-gap-override: 0%;
  }

  :root {
    --color-bg:           #F9F9F7;
    --color-text:         #1a1714;
    --color-text-muted:   #726d66;
    --color-accent:       #9c7040;
    --color-accent-hover: #7d5a30;
    --color-rule:         #1a1714;
    --color-rule-light:   #d4ccc0;
    --color-annotation:   #a09890;
    --annotation-ink:     #8B7355;
    --annotation-rule:    #C4B89A;

    --font-display: 'Big Shoulders Display', sans-serif;
    --font-serif:   'Playfair Display', 'Playfair Display Fallback', Georgia, serif;
    --font-sans:    'Inter', system-ui, sans-serif;

    --container-max: 1100px;
    --space-xs:  0.5rem;
    --space-sm:  1rem;
    --space-md:  2rem;
    --space-lg:  4rem;
    --space-xl:  6rem;
    --space-2xl: 7rem;
  }

  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    font-size: 16px;
  }

  body {
    font-family: var(--font-sans);
    background-color: var(--color-bg);
    color: var(--color-text);
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  /* ── Container ── */
  .container {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  @media (min-width: 640px)  { .container { padding: 0 2.5rem; } }
  @media (min-width: 1024px) { .container { padding: 0 4rem;   } }

  /* ── Typography ── */
  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-serif);
    font-weight: 400;
    line-height: 1.1;
    color: var(--color-text);
  }

  p {
    font-family: var(--font-sans);
    font-weight: 400;
    color: var(--color-text-muted);
    line-height: 1.75;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  /* Inline prose links — distinct from nav/UI links */
  p a {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--color-accent) 40%, transparent);
    text-underline-offset: 0.2em;
    transition: color 0.2s ease, text-decoration-color 0.2s ease;
  }

  p a:hover {
    color: var(--color-accent-hover);
    text-decoration-color: var(--color-accent-hover);
  }

  /* ── Utilities ── */
  .label {
    font-family: var(--font-serif);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-annotation);
  }

  .section-label {
    font-family: var(--font-serif);
    font-size: 0.6875rem;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    display: block;
  }

  .annotation {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.875rem;
    font-weight: 400;
    color: var(--color-annotation);
    line-height: 1.6;
    letter-spacing: 0.01em;
  }

  hr.rule {
    border: none;
    border-top: 1px solid var(--color-rule);
  }

  hr.rule--light {
    border-top-color: var(--color-rule-light);
  }

  .fig-label {
    font-family: var(--font-serif);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--annotation-ink);
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .fig-label::after {
    content: '';
    flex: 1;
    border-top: 0.5px solid var(--annotation-rule);
  }

  .specimen-label {
    font-family: var(--font-serif);
    font-size: 0.6875rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--annotation-ink);
  }

  .section {
    padding: var(--space-lg) 0;
  }

  @media (min-width: 768px) {
    .section {
      padding: var(--space-xl) 0;
    }
  }
</style>

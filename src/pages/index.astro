<script>
  // Fallback scroll observer for browsers without animation-timeline: view()
  if (!CSS.supports('animation-timeline', 'view()')) {
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        const isRule = e.target.hasAttribute('data-rule');
        if (e.isIntersecting) {
          e.target.classList.add('in-view');
          if (!isRule) obs.unobserve(e.target);
        } else if (isRule && e.boundingClientRect.top > window.innerHeight) {
          e.target.classList.remove('in-view');
        }
      });
    }, { threshold: 0.05 });
    document.querySelectorAll('[data-slide], [data-rule]').forEach(el => obs.observe(el));
  }
</script>

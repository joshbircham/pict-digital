---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Pict Digital | Creative Consultancy, Aberdeen">
  <Navigation />

  <main>

    <!-- ──────────────────────────────────────
         HERO
    ────────────────────────────────────── -->
    <section class="hero" id="hero">
      <div class="container">
        <div class="hero-inner">
          <div class="hero-eyebrow">
            <span class="label">PICT DIGITAL &mdash; Aberdeen, Scotland</span>
          </div>
          <h1 class="hero-title">
            Worthwhile<br />creative work.
          </h1>
          <hr class="rule hero-rule" aria-hidden="true" />
          <p class="hero-sub">
            Narrative video, creative strategy, and place-based storytelling. Aberdeen, Scotland.
          </p>
        </div>
      </div>
    </section>


    <!-- ──────────────────────────────────────
         ABOUT
    ────────────────────────────────────── -->
    <section id="about" class="about section">
      <div class="container">
        <hr class="rule rule--light section-top-rule rule-slide" aria-hidden="true" />

        <span class="section-label" data-slide>About</span>

        <div class="about-body">

          <div class="about-text" data-slide>
            <h2>Josh Bircham</h2>
            <p class="about-lead">
              Josh Bircham is a Senior Lecturer in Digital Marketing at Robert Gordon University and the founder of Pict Digital.
            </p>
            <p>
              His practice sits at the intersection of academic research and applied creative work — bringing
              the same depth of thought to a short documentary as to a long-form campaign
              strategy. He has worked with broadcasters, cultural institutions, heritage bodies,
              and arts organisations across Scotland and beyond.
            </p>
            <p>
              He is a published author, a Fellow of the Higher Education Academy, and an External Examiner
              at Ravensbourne University London. He is currently completing a PhD at RGU.
            </p>
            <p>
              Pict Digital takes on a small number of projects each year.
            </p>
            <p class="annotation">
              AI-informed workflows &nbsp;·&nbsp; Documentary approach &nbsp;·&nbsp; Theory in practice
            </p>
          </div>

          <aside class="about-credentials" aria-label="Credentials" data-slide="right">

            <dl class="credentials-block">
              <dt class="label">field notes</dt>
              <dd>MA</dd>
              <dd>MSc</dd>
              <dd>FHEA</dd>
              <dd>PhD Candidate</dd>
            </dl>

            <dl class="credentials-block">
              <dt class="label">habitat</dt>
              <dd>Senior Lecturer<br />Digital Marketing</dd>
              <dd class="credentials-institution">Robert Gordon University<br />Aberdeen, Scotland</dd>
            </dl>

            <dl class="credentials-block">
              <dt class="label">observed range</dt>
              <dd>Narrative Video</dd>
              <dd>Creative Campaigns</dd>
              <dd>Place &amp; Culture</dd>
              <dd>AI Strategy</dd>
            </dl>

          </aside>

        </div>
      </div>
    </section>


    <!-- ──────────────────────────────────────
         SERVICES
    ────────────────────────────────────── -->
    <section id="services" class="services section">
      <div class="container">
        <hr class="rule rule--light section-top-rule rule-slide" aria-hidden="true" />

        <span class="section-label" data-slide>Services</span>

        <div class="services-list">

          <article class="service-item" data-slide style="--stagger:0">
            <div class="service-number">
              <span class="fig-label">fig.&nbsp;i</span>
            </div>
            <div class="service-content">
              <h3>Narrative Video</h3>
              <p>
                Cinematic storytelling that captures the character of place and the texture of
                lived experience. Documentary-style narratives, branded films, and cultural
                documentation made with genuine craft.
              </p>
              <p class="annotation">
                Place-based documentary &nbsp;·&nbsp; Brand films &nbsp;·&nbsp; Cultural documentation
              </p>
            </div>
          </article>

          <article class="service-item" data-slide style="--stagger:1">
            <div class="service-number">
              <span class="fig-label">fig.&nbsp;ii</span>
            </div>
            <div class="service-content">
              <h3>Creative Consultancy</h3>
              <p>
                Strategic creative direction informed by deep expertise in digital marketing
                and content strategy. Campaign development, creative review, and the kind of
                critical thinking that sharpens good ideas into great ones.
              </p>
              <p class="annotation">
                Campaign strategy &nbsp;·&nbsp; Creative direction &nbsp;·&nbsp; Digital marketing
              </p>
            </div>
          </article>

          <article class="service-item" data-slide style="--stagger:2">
            <div class="service-number">
              <span class="fig-label">fig.&nbsp;iii</span>
            </div>
            <div class="service-content">
              <h3>Place &amp; Culture</h3>
              <p>
                Projects that honour the specificity of Scottish landscapes, communities, and
                cultural heritage. Authentic representation for cultural institutions, heritage
                bodies, and place-promotion initiatives.
              </p>
              <p class="annotation">
                Cultural heritage &nbsp;·&nbsp; Scottish landscapes &nbsp;·&nbsp; Community storytelling
              </p>
            </div>
          </article>

          <article class="service-item" data-slide style="--stagger:3">
            <div class="service-number">
              <span class="fig-label">fig.&nbsp;iv</span>
            </div>
            <div class="service-content">
              <h3>AI Strategy</h3>
              <p>
                AI-informed strategy for organisations navigating what these tools actually mean in practice.
              </p>
              <p class="annotation">
                AI strategy &nbsp;·&nbsp; Workflow &nbsp;·&nbsp; Critical adoption
              </p>
            </div>
          </article>

        </div>
      </div>
    </section>


    <!-- ──────────────────────────────────────
         CLIENTS
    ────────────────────────────────────── -->
    <section id="clients" class="clients section">
      <div class="container">
        <hr class="rule rule--light section-top-rule rule-slide" aria-hidden="true" />

        <span class="section-label" data-slide>Selected Clients</span>

        <ul class="clients-list" role="list">
          <li class="client-item" data-slide>
            <span class="client-name">StAnza Poetry Festival</span>
            <span class="annotation">Cultural programming</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">BBC</span>
            <span class="annotation">Regional content production</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">Historic Environment Scotland</span>
            <span class="annotation">Heritage interpretation</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">Scottish Government</span>
            <span class="annotation">Public engagement campaigns</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">Linen Hall Library</span>
            <span class="annotation">Cultural institution</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">Aberdeenshire Council</span>
            <span class="annotation">Place promotion</span>
          </li>
        </ul>

      </div>
    </section>


    <!-- ──────────────────────────────────────
         CONTACT
    ────────────────────────────────────── -->
    <section id="contact" class="contact section">
      <div class="container">
        <hr class="rule rule--light section-top-rule rule-slide" aria-hidden="true" />

        <div class="contact-inner">

          <div class="contact-text" data-slide>
            <span class="section-label">Contact</span>
            <h2>Let's work<br />together.</h2>
            <p>
              Every project begins with a conversation. If you're working on something
              that calls for genuine narrative craft: a film, a campaign, a creative
              strategy. I'd welcome the chance to hear about it.
            </p>
            <p class="annotation">
              Aberdeen, Scotland &nbsp;·&nbsp; Solo practitioner &nbsp;·&nbsp; Direct collaboration
            </p>
          </div>

          <div class="contact-action" data-slide="right">
            <a href="mailto:hello@pictdigital.com" class="cta-link">
              <span class="cta-email">hello@pictdigital.com</span>
              <span class="label cta-prompt">Begin a conversation</span>
            </a>
          </div>

        </div>
      </div>
    </section>


    <!-- ──────────────────────────────────────
         FOOTER
    ────────────────────────────────────── -->
    <footer class="footer">
      <div class="container">
        <hr class="rule rule--light" aria-hidden="true" />
        <div class="footer-inner">
          <div class="footer-left">
            <span class="label">Pict Digital</span>
            <span class="label">Aberdeen, Scotland</span>
            <span class="label">© 2026</span>
          </div>
          <nav class="footer-social" aria-label="Social links">
            <a href="https://instagram.com/josh.bircham" class="specimen-label" target="_blank" rel="noopener">IG</a>
            <a href="https://tiktok.com/@josh.bircham" class="specimen-label" target="_blank" rel="noopener">TK</a>
            <a href="https://linkedin.com/in/josh-bircham" class="specimen-label" target="_blank" rel="noopener">LI</a>
          </nav>
        </div>
      </div>
    </footer>

  </main>
</Layout>


<style>



  /* ──────────────────────────────────────
     SCROLL SLIDE-IN
     Left-aligned elements slide from left;
     right-aligned elements slide from right.
     Rules draw width from left to right.
  ────────────────────────────────────── */

  [data-slide] {
    opacity: 0;
    transform: translateX(-56px);
    transition:
      opacity   0.55s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.55s cubic-bezier(0.16, 1, 0.3, 1);
    transition-delay: calc(var(--stagger, 0) * 70ms);
  }

  [data-slide="right"] {
    transform: translateX(56px);
  }

  [data-slide].in-view {
    opacity: 1;
    transform: translateX(0);
  }

  /* Rules extend from left */
  .rule-slide {
    transform-origin: left center;
    transform: scaleX(0);
    transition: transform 0.75s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .rule-slide.in-view {
    transform: scaleX(1);
  }

  @media (prefers-reduced-motion: reduce) {
    [data-slide], .rule-slide {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }


  /* ──────────────────────────────────────
     HERO
  ────────────────────────────────────── */

  .hero {
    padding-top: 8rem;
    padding-bottom: var(--space-xl);
  }

  .hero-inner {
    max-width: 680px;
  }

  .hero-eyebrow {
    margin-bottom: 2rem;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .hero-rule {
    max-width: 340px;
    margin-bottom: 1.75rem;
  }

  .hero-sub {
    max-width: 400px;
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-muted);
  }


  /* ──────────────────────────────────────
     SECTION COMMON
  ────────────────────────────────────── */

  .section-top-rule { margin-bottom: 2.5rem; }
  .section-label    { margin-bottom: 3rem; }


  /* ──────────────────────────────────────
     ABOUT
  ────────────────────────────────────── */

  .about { padding-top: 5rem; }
  @media (min-width: 768px) { .about { padding-top: 6rem; } }

  .about-body {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
  }

  @media (min-width: 768px) {
    .about-body { grid-template-columns: 3fr 2fr; gap: 5rem; }
  }

  .about-text h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1.5rem;
  }

  .about-lead {
    font-size: 1.1rem;
    font-weight: 400;
    color: var(--color-text);
    margin-bottom: 1.5rem;
    line-height: 1.7;
  }

  .about-text p { margin-bottom: 1.25rem; }

  .about-credentials {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .credentials-block {
    border-top: 1px solid var(--color-rule-light);
    padding-top: 1rem;
  }

  .credentials-block dt {
    display: block;
    margin-bottom: 0.9rem;
  }

  .credentials-block dd {
    font-family: var(--font-serif);
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.4;
    margin-bottom: 0.4rem;
  }

  .credentials-block dd.credentials-institution {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-top: 0.3rem;
  }


  /* ──────────────────────────────────────
     SERVICES
  ────────────────────────────────────── */

  .services-list { display: flex; flex-direction: column; }

  .service-item {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0 2rem;
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-rule-light);
  }

  .service-item:first-of-type { border-top: 1px solid var(--color-rule-light); }

  .service-number { padding-top: 0.3rem; }

  .service-content h3 {
    font-size: clamp(1.3rem, 2.5vw, 1.65rem);
    font-weight: 500;
    margin-bottom: 1rem;
  }

  .service-content p { max-width: 580px; margin-bottom: 0.75rem; }

  @media (max-width: 480px) {
    .service-item {
      grid-template-columns: 1fr;
      gap: 0.5rem;
      padding: 2.5rem 0;
    }
  }


  /* ──────────────────────────────────────
     CLIENTS
  ────────────────────────────────────── */

  .clients-list { list-style: none; display: flex; flex-direction: column; }

  .client-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-rule-light);
    gap: 1.5rem;
  }

  .client-item:first-child { border-top: 1px solid var(--color-rule-light); }

  .client-name {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: var(--color-text);
    font-weight: 400;
  }

  .client-item .annotation { text-align: right; flex-shrink: 0; }

  @media (max-width: 480px) {
    .client-item { flex-direction: column; align-items: flex-start; gap: 0.2rem; }
    .client-item .annotation { text-align: left; }
  }


  /* ──────────────────────────────────────
     CONTACT
  ────────────────────────────────────── */

  .contact-inner { display: grid; grid-template-columns: 1fr; gap: 4rem; }

  @media (min-width: 768px) {
    .contact-inner { grid-template-columns: 1fr 1fr; gap: 6rem; align-items: end; }
  }

  .contact-text .section-label { margin-bottom: 1.5rem; }

  .contact-text h2 {
    font-size: clamp(2rem, 4vw, 2.75rem);
    margin-bottom: 1.5rem;
  }

  .contact-text p { margin-bottom: 1rem; max-width: 400px; }

  .contact-action { padding-bottom: 0.5rem; }

  .cta-link {
    display: inline-flex;
    flex-direction: column;
    gap: 0.6rem;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .cta-email {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-weight: 400;
    border-bottom: 1px solid var(--color-rule);
    padding-bottom: 0.3rem;
    transition: border-color 0.2s ease, color 0.2s ease;
  }

  .cta-link:hover .cta-email {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .cta-prompt {
    color: var(--color-annotation);
    transition: color 0.2s ease;
  }

  .cta-link:hover .cta-prompt { color: var(--color-accent); }


  /* ──────────────────────────────────────
     FOOTER
  ────────────────────────────────────── */

  .footer { padding: 3rem 0; }
  .footer hr { margin-bottom: 1.5rem; }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .footer-left {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .footer-social {
    display: flex;
    gap: 1.5rem;
  }

  .footer-social a {
    color: var(--annotation-ink);
    transition: color 0.2s ease;
  }

  .footer-social a:hover {
    color: var(--color-accent);
  }

</style>


<script>
  // Scroll slide-in: left-aligned from left, right-aligned from right, rules extend width
  const slideObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('in-view');
        slideObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08, rootMargin: '0px 0px -32px 0px' });

  document.querySelectorAll('[data-slide], .rule-slide')
    .forEach(el => slideObserver.observe(el));
</script>



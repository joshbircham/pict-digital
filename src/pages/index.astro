---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
---

<Layout title="Pict Digital | Creative Consultancy, Aberdeen">
  <Navigation />

  <main>

    <!-- ──────────────────────────────────────
         MASTHEAD — large centred logo
    ────────────────────────────────────── -->
    <header class="masthead">
      <div class="container masthead-inner">
        <a href="/" class="masthead-logo" aria-label="Pict Digital - home">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 147.03 150.95" aria-hidden="true" focusable="false">
            <path d="M28.82,30.62q-4-4.05-12.79-4.05H0v123.3H7V99.4h8.86q8.87,0,12.91-4.05T33.14,82q.45-9.09.46-17.92T33.14,44Q32.83,34.67,28.82,30.62ZM26.43,69.27q-.08,6.32-.31,12.94-.23,5.7-2.54,8.21t-7.71,2.5H7V33.05h9q5.24,0,7.55,2.54C25.12,37.28,26,40,26.12,43.76q.24,6.63.31,12.91T26.43,69.27Z"/>
            <rect x="46.47" y="26.57" width="7.01" height="123.3"/>
            <path d="M97.4,105.87q.07,4.55.16,9.32t.07,9.6q0,4.81-.07,9.36c-.06,3.85-.89,6.59-2.51,8.21s-4.38,2.42-8.28,2.42c-3.45,0-5.91-.81-7.4-2.42S77.08,138,77,134.15q-.23-12.25-.35-23.58t-.11-22.31q0-11,.11-22.23T77,42.45c.1-3.91.89-6.63,2.35-8.17a7.45,7.45,0,0,1,4-2v0L87,101.26l4-68.79a7.52,7.52,0,0,1,3.54,1.81q2.31,2.31,2.39,8.17.07,4.23.11,8.67t0,8.82q0,4.39-.11,8.63h7c0-2,.09-4.6.12-7.78s0-6.38,0-9.6-.07-5.84-.12-7.9q-.23-9.39-4.27-13.44-3-3-8.66-3.76V0H83.31V26c-4.1.46-7.23,1.77-9.3,4q-3.89,4.24-4,13.25-.24,12-.31,23.05t-.08,22q0,10.86.08,21.92T70,133.3q.15,9.4,4,13.53T86.77,151c6.21,0,10.7-1.38,13.44-4.12s4.2-7.26,4.36-13.53q.23-7.23.15-13.72t-.31-13.71Z"/>
            <polygon points="110.66 26.57 110.66 33.05 125.37 33.05 125.37 149.87 132.39 149.87 132.39 33.05 147.03 33.05 147.03 26.57 110.66 26.57"/>
          </svg>
        </a>
      </div>
    </header>


    <!-- ──────────────────────────────────────
         HERO
    ────────────────────────────────────── -->
    <section class="hero" id="hero">
      <div class="container hero-container">

        <!-- Left: Text content -->
        <div class="hero-inner">
          <h1 class="hero-title">
            Creative digital<br />consultancy.
          </h1>
          <hr class="rule hero-rule" aria-hidden="true" />
          <p class="hero-sub">
            Campaign strategy, digital marketing, content creation and narrative video. Based in Aberdeen, Scotland.
          </p>
        </div>

        <!-- Right: Forest photograph -->
        <div class="hero-photo-wrapper">
          <div class="hero-photo-frame">
            <div class="hero-photo-inner">
              <img
                src="/images/pict-forest-image.jpg"
                alt="Pine forest path, Aberdeenshire"
                class="hero-photo"
              />
            </div>
          </div>
        </div>

      </div>
    </section>


    <!-- ──────────────────────────────────────
         SOFT CONTACT FORM
    ────────────────────────────────────── -->
    <section class="soft-contact section" id="soft-contact">
      <div class="container">
        <hr class="rule rule--light section-top-rule" data-rule aria-hidden="true" />

        <div class="soft-contact-inner">
          <div class="soft-contact-text">
            <h2 data-slide>Got something<br />you want to<br />talk about?</h2>
            <p data-slide>
              Every project begins with a conversation.
              Drop a note and we'll get back to you directly.
            </p>
            <p class="soft-contact-email annotation" data-slide>
              Or email directly:<br />
              <a href="mailto:hello@pictdigital.com">hello@pictdigital.com</a>
            </p>
          </div>

          <form
            class="contact-form"
            action="https://formspree.io/f/xjgpogwq"
            method="POST"
            data-slide="right"
          >
            <input type="hidden" name="_subject" value="New enquiry from pictdigital.com" />

            <div class="form-field">
              <label for="name" class="form-label specimen-label">Name</label>
              <input type="text" id="name" name="name" required autocomplete="name" />
            </div>

            <div class="form-field">
              <label for="email" class="form-label specimen-label">Email</label>
              <input type="email" id="email" name="email" required autocomplete="email" />
            </div>

            <div class="form-field">
              <label for="message" class="form-label specimen-label">Message</label>
              <textarea id="message" name="message" rows="4" placeholder="Tell us a bit about what you're thinking..." required></textarea>
            </div>

            <button type="submit" class="form-submit">
              Send it over <span class="form-arrow" aria-hidden="true">→</span>
            </button>
          </form>
        </div>
      </div>
    </section>


    <!-- ──────────────────────────────────────
         WHAT WE OFFER
    ────────────────────────────────────── -->
    <section id="offer" class="offer section">
      <div class="container">
        <hr class="rule rule--light section-top-rule" data-rule aria-hidden="true" />

        <span class="section-label" data-slide>What We Offer</span>

        <div class="offer-list">

          <article class="offer-item">
            <div class="offer-content">
              <h3 data-slide>Creative Campaigns</h3>
              <p data-slide>
                Campaign strategy and production for brands that want to say something real. Photography, content, and storytelling across channels.
              </p>
            </div>
            <span class="offer-tag specimen-label" data-slide>Brands &amp; Institutions</span>
          </article>

          <article class="offer-item">
            <div class="offer-content">
              <h3 data-slide>Narrative Video &amp; Film</h3>
              <p data-slide>
                Documentary-quality video for cultural organisations, heritage bodies, and arts institutions. From concept through post-production.
              </p>
            </div>
            <span class="offer-tag specimen-label" data-slide>Cultural &amp; Heritage</span>
          </article>

          <article class="offer-item">
            <div class="offer-content">
              <h3 data-slide>Digital Marketing Strategy</h3>
              <p data-slide>
                Data-informed marketing strategy, analytics, and AI-informed planning. Grounded in academic rigour and commercial pragmatism.
              </p>
            </div>
            <span class="offer-tag specimen-label" data-slide>Strategy &amp; Analysis</span>
          </article>

          <article class="offer-item">
            <div class="offer-content">
              <h3 data-slide>Social Media &amp; Content</h3>
              <p data-slide>
                Strategy and hands-on content creation for social platforms. Built on real audience-building experience - <a href="https://tiktok.com/@josh.bircham" target="_blank" rel="noopener">28,000+ followers in vintage fashion</a> - and academic research into how these platforms actually work.
              </p>
            </div>
            <span class="offer-tag specimen-label" data-slide>Platforms &amp; Audiences</span>
          </article>

          <article class="offer-item">
            <div class="offer-content">
              <h3 data-slide>Place &amp; Culture</h3>
              <p data-slide>
                Place-based storytelling for Scotland and beyond. Working with communities, landscapes, and the stories that belong to specific places.
              </p>
            </div>
            <span class="offer-tag specimen-label" data-slide>Scotland &amp; Beyond</span>
          </article>

        </div>
      </div>
    </section>




    <!-- ──────────────────────────────────────
         ABOUT
    ────────────────────────────────────── -->
    <section id="about" class="about section">
      <div class="container">
        <hr class="rule rule--light section-top-rule" data-rule aria-hidden="true" />

        <span class="section-label" data-slide>About</span>

        <div class="about-body">

          <div class="about-text">
            <h2 data-slide>Josh Bircham</h2>
            <p class="about-lead" data-slide>
              Josh Bircham is a <a href="https://rgu-repository.worktribe.com/person/799869/josh-bircham" target="_blank" rel="noopener">Senior Lecturer in Digital Marketing at Robert Gordon University</a> and the founder of Pict Digital.
            </p>

            <span class="about-subsection-label specimen-label" data-slide>Practice</span>
            <p data-slide>
              His practice sits at the intersection of academic research and applied creative work — bringing
              the same depth of thought to a short documentary as to a long-form campaign
              strategy. He has worked with broadcasters, cultural institutions, heritage bodies,
              and arts organisations across Scotland and beyond.
            </p>

            <span class="about-subsection-label specimen-label" data-slide>Recognition</span>
            <p data-slide>
              He is a <a href="https://www.amazon.co.uk/We-are-56-Josh-Bircham/dp/1910449512" target="_blank" rel="noopener">published author</a>, a Fellow of the Higher Education Academy, and is currently completing a PhD at RGU.
            </p>

            <span class="about-subsection-label specimen-label" data-slide>Availability</span>
            <p data-slide>
              Pict Digital takes on a small number of projects each year.
            </p>

            <p class="annotation about-footnote" data-slide>
              AI-informed workflows &nbsp;·&nbsp; Documentary approach &nbsp;·&nbsp; Theory in practice
            </p>
          </div>

          <aside class="about-credentials" aria-label="Credentials">

            <dl class="credentials-block" data-slide="right">
              <dt class="label">Qualifications &amp; Recognition</dt>
              <dd>MA English Literature (Aberdeen)</dd>
              <dd>MSc Digital Marketing with Distinction (RGU)</dd>
              <dd>FHEA</dd>
              <dd>PhD Candidate (RGU, 2023–present)</dd>
            </dl>

            <dl class="credentials-block" data-slide="right">
              <dt class="label">Role &amp; Position</dt>
              <dd>Senior Lecturer in Digital Marketing</dd>
              <dd class="credentials-institution">Robert Gordon University<br />Aberdeen Business School</dd>
              <dd class="credentials-institution">Founder, Pict Digital</dd>
            </dl>

            <dl class="credentials-block" data-slide="right">
              <dt class="label">Areas of Expertise</dt>
              <dd>Narrative Video</dd>
              <dd>Creative Campaigns</dd>
              <dd>Place &amp; Culture</dd>
              <dd>Digital Marketing Strategy</dd>
              <dd>Social Media Content</dd>
              <dd>AI-Informed Marketing</dd>
              <dd>Semiotics &amp; Cultural Analysis</dd>
            </dl>

          </aside>

        </div>
      </div>
    </section>


    <!-- ──────────────────────────────────────
         CLIENTS
    ────────────────────────────────────── -->
    <section id="clients" class="clients section">
      <div class="container">
        <hr class="rule rule--light section-top-rule" data-rule aria-hidden="true" />

        <span class="section-label" data-slide>Selected Clients</span>

        <ul class="clients-list" role="list">
          <li class="client-item" data-slide>
            <span class="client-name">StAnza Poetry Festival</span>
            <span class="annotation">Digital Campaign Management</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">BBC</span>
            <span class="annotation">Social content production</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">Historic Environment Scotland</span>
            <span class="annotation">Narrative documentary</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">Linen Hall Library</span>
            <span class="annotation">Cultural institution</span>
          </li>
          <li class="client-item" data-slide>
            <span class="client-name">Aberdeenshire Council</span>
            <span class="annotation">Place promotion</span>
          </li>
        </ul>

      </div>
    </section>


    <!-- ──────────────────────────────────────
         FIELD NOTES
    ────────────────────────────────────── -->
    <section id="posts" class="posts section">
      <div class="container">
        <hr class="rule rule--light section-top-rule" data-rule aria-hidden="true" />

        <div class="posts-header">
          <div class="posts-header-left">
            <span class="section-label" data-slide>Field Notes</span>
            <p class="posts-descriptor annotation" data-slide>Writing on practice, strategy, and the work.</p>
          </div>
          <a href="/posts" class="posts-all specimen-label" data-slide="right">All notes →</a>
        </div>

        <div class="posts-grid">

          <article class="post-card" data-slide>
            <a href="/posts/why-your-small-business-doesnt-need-a-rebrand" class="post-card-link">
              <div class="post-card-image">
                <img src="/images/post-images/narrative-branding-for-business.jpg" alt="A figure at a desk surrounded by handwritten story notes, seen from behind in warm amber light" />
              </div>
              <div class="post-card-meta">
                <span class="specimen-label post-category">Strategy</span>
                <time class="specimen-label post-date">March 2026</time>
              </div>
              <h3 class="post-card-title">Your brand story is not about you</h3>
              <p class="post-card-excerpt">Most small businesses tell brand stories about themselves. The ones that build real trust tell stories about their customers - and understand exactly why that difference matters.</p>
              <span class="post-card-read specimen-label">Read →</span>
            </a>
          </article>

        </div>
      </div>
    </section>


    <!-- ──────────────────────────────────────
         CONTACT (bottom)
    ────────────────────────────────────── -->
    <section id="contact" class="contact section">
      <div class="container">
        <hr class="rule rule--light section-top-rule" data-rule aria-hidden="true" />

        <div class="contact-inner">

          <div class="contact-text">
            <span class="section-label" data-slide>Contact</span>
            <h2 data-slide>Let's work<br />together.</h2>
            <p data-slide>
              Every project begins with a conversation. If you're working on something
              that calls for genuine narrative craft - a film, a campaign, a creative
              strategy - I'd welcome the chance to hear about it.
            </p>
            <p class="annotation" data-slide>
              Aberdeen, Scotland &nbsp;·&nbsp; Expert practitioner &nbsp;·&nbsp; Let's Collaborate
            </p>
          </div>

          <div class="contact-action">
            <a href="mailto:hello@pictdigital.com" class="cta-link" data-slide="right">
              <span class="cta-email">hello@pictdigital.com</span>
              <span class="label cta-prompt">Drop me an email - we'll get back to you</span>
            </a>
            <nav class="contact-social" aria-label="Social links">
              <a href="https://www.instagram.com/pictdigital" class="specimen-label" target="_blank" rel="noopener">Instagram</a>
              <a href="https://www.youtube.com/@pict.digital" class="specimen-label" target="_blank" rel="noopener">YouTube</a>
              <a href="https://www.linkedin.com/company/pictdigital/" class="specimen-label" target="_blank" rel="noopener">LinkedIn</a>
            </nav>
          </div>

        </div>
      </div>
    </section>


    <!-- ──────────────────────────────────────
         FOOTER
    ────────────────────────────────────── -->
    <footer class="footer">
      <div class="container">
        <hr class="rule rule--light" aria-hidden="true" />
        <div class="footer-inner">
          <div class="footer-left">
            <span class="label">Pict Digital</span>
            <span class="label">Aberdeen | Scotland</span>
            <span class="label">© 2026</span>
          </div>
          <nav class="footer-social" aria-label="Social links">
            <a href="https://www.instagram.com/pictdigital" class="specimen-label" target="_blank" rel="noopener">IG</a>
            <a href="https://www.youtube.com/@pict.digital" class="specimen-label" target="_blank" rel="noopener">YT</a>
            <a href="https://www.linkedin.com/company/pictdigital/" class="specimen-label" target="_blank" rel="noopener">LI</a>
          </nav>
        </div>
      </div>
    </footer>

  </main>
</Layout>


<style is:global>
  @keyframes rule-draw {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }

  [data-rule]         { transform-origin: left center; }
  [data-rule="right"] { transform-origin: right center; }

  @supports (animation-timeline: view()) {
    [data-rule], .credentials-block::before {
      animation: rule-draw linear both;
      animation-timeline: view();
      animation-range: entry 0% cover 50%;
    }
  }

  @supports not (animation-timeline: view()) {
    [data-rule] {
      transform: scaleX(0);
      transition: transform 1.1s cubic-bezier(0.25, 1, 0.5, 1);
    }
    [data-rule].in-view { transform: scaleX(1); }
  }

  .credentials-block::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: var(--color-rule-light);
    transform-origin: right center;
    transform: scaleX(0);
  }

  @supports not (animation-timeline: view()) {
    .credentials-block::before {
      transition: transform 1.1s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .credentials-block.in-view::before { transform: scaleX(1); }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-rule], .credentials-block::before {
      animation: none !important;
      transform: scaleX(1) !important;
      transition: none !important;
    }
  }
</style>

<style>
  /* ── Scroll-driven slide-in ── */
  @keyframes slide-in {
    from { opacity: 0; transform: translateX(var(--slide-x, -130px)); }
    to   { opacity: 1; transform: translateX(0); }
  }

  @supports (animation-timeline: view()) {
    [data-slide] {
      --slide-x: -80px;
      animation: slide-in linear both;
      animation-timeline: view();
      /* Start as element enters, finish once it's well into view */
      animation-range: entry 0% cover 20%;
    }
    [data-slide="right"] { --slide-x: 80px; }

    @media (max-width: 767px) {
      [data-slide],
      [data-slide="right"] { --slide-x: 0px; animation-range: entry 0% cover 15%; }
    }
  }

  @supports not (animation-timeline: view()) {
    [data-slide] {
      opacity: 0;
      transform: translateX(-80px);
      transition: opacity 0.9s cubic-bezier(0.16, 1, 0.3, 1),
                  transform 0.9s cubic-bezier(0.16, 1, 0.3, 1);
    }
    [data-slide="right"] { transform: translateX(80px); }
    [data-slide].in-view { opacity: 1; transform: translateX(0); }

    @media (max-width: 767px) {
      [data-slide],
      [data-slide="right"] { transform: none; }
    }
  }

  @media (prefers-reduced-motion: reduce) {
    [data-slide] {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }
  }


  /* ── MASTHEAD ── */
  .masthead {
    padding-top: 4.5rem; /* clear fixed nav */
    padding-bottom: 1.5rem;
    text-align: center;
    border-bottom: 1px solid var(--color-rule-light);
  }

  .masthead-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .masthead-logo {
    display: inline-block;
    color: var(--color-text);
    transition: color 0.2s ease;
  }

  .masthead-logo:hover { color: var(--color-accent); }

  .masthead-logo svg {
    height: clamp(4rem, 8vw, 6.5rem);
    width: auto;
    fill: currentColor;
  }

  .masthead-location {
    color: var(--color-annotation);
  }


  /* ── HERO ── */
  .hero {
    padding-top: 0;
    padding-bottom: 0;
    overflow: hidden;
    border-bottom: 1px solid var(--color-rule-light);
  }

  .hero-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0;
  }

  @media (min-width: 768px) {
    .hero-container {
      display: grid;
      grid-template-columns: 1fr 48%;
      gap: 0;
      align-items: stretch;
      /* Remove right padding so photo can bleed to edge */
      padding-right: 0;
      /* Height: fill viewport so next section only enters on scroll */
      height: clamp(520px, 74vh, 740px);
    }
  }

  .hero-inner {
    flex: 1;
    max-width: 560px;
    padding-top: var(--space-lg);
    padding-bottom: var(--space-md);
  }

  @media (min-width: 768px) {
    .hero-inner {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding-right: 3.5rem;
      padding-top: clamp(2rem, 3vh, 3rem);
      padding-bottom: clamp(2rem, 3vh, 3rem);
    }
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(3rem, 6vw, 5.5rem);
    font-weight: 700;
    line-height: 1.05;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: 2.5rem;
  }

  .hero-rule {
    max-width: 340px;
    margin-bottom: 1.75rem;
  }

  .hero-sub {
    max-width: 400px;
    font-size: 1rem;
    font-weight: 300;
    line-height: 1.75;
    color: var(--color-text-muted);
  }

  /* Photo — full-bleed right on desktop */
  .hero-photo-wrapper {
    width: 100%;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .hero-photo-wrapper {
      /* Extend beyond container to reach viewport right edge */
      margin-right: calc(-1 * max(0px, (100vw - 1100px) / 2));
      height: 100%;
    }
  }

  @media (max-width: 767px) {
    .hero {
      padding: 0;
    }

    /* Tall hero — text sits in upper portion, path visible below */
    .hero-container {
      position: relative;
      min-height: 130vw;
      display: flex;
      flex-direction: column;
      justify-content: flex-start;
      align-items: flex-start;
      gap: 0;
      padding-top: 28vw;
      padding-bottom: 0;
    }

    /* Photo fills edge-to-edge, full height of hero */
    .hero-photo-wrapper {
      position: absolute;
      top: 0;
      left: -1.5rem;
      right: -1.5rem;
      bottom: 0;
      width: calc(100% + 3rem);
      max-height: none;
      margin: 0;
      order: 0;
    }

    .hero-photo-frame {
      height: 100%;
      border: none;
    }

    /* Box sized to content */
    .hero-inner {
      flex: none;
      position: relative;
      z-index: 1;
      background-color: rgba(249, 249, 247, 0.82);
      padding: 1.1rem 1.5rem 1.25rem;
      max-width: none;
      width: 100%;
      padding-top: 1.1rem;
      padding-bottom: 1.25rem;
    }

    .hero-title {
      margin-bottom: 1rem;
    }

    .hero-rule {
      margin-bottom: 0.75rem;
    }
  }

  .hero-photo-frame {
    overflow: hidden;
    border: none;
    position: relative;
    height: 100%;
  }

  .hero-photo-inner {
    height: 100%;
  }

  @keyframes ken-burns {
    0%   { transform: scale(1)    translate(0, 0); }
    50%  { transform: scale(1.06) translate(-1%, 0); }
    100% { transform: scale(1)    translate(0, 0); }
  }

  .hero-photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    animation: ken-burns 18s ease-in-out infinite;
    will-change: transform;
    min-height: 400px;
  }

  @media (max-width: 767px) {
    .hero-photo {
      height: 100%;
      object-position: center bottom;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-photo { animation: none; }
  }

